package com.rays.drone;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ResourceBundle;

public class DroneModel {
	
	ResourceBundle rb = ResourceBundle.getBundle("com.rays.bundle.app");

	    String driver = rb.getString("driver");
	    String url = rb.getString("url");
	    String username = rb.getString("username");
	    String password = rb.getString("password");
	    
	    public int nextPk() throws Exception {

	        int pk = 0;

	        Class.forName(driver);

	        Connection conn = DriverManager.getConnection(url, username, password);

	        PreparedStatement pstmt = conn.prepareStatement("select max(droneId) from drone_delivery");

	        ResultSet rs = pstmt.executeQuery();

	        while (rs.next()) {
	            pk = rs.getInt(1);
	        }

	        return pk + 1;
	    }
	    
	    public void add(DroneBean bean) throws Exception {

	        Connection conn = null;

	        try {

	            Class.forName(driver);

	            conn = DriverManager.getConnection(url, username, password);

	            conn.setAutoCommit(false);

	            PreparedStatement pstmt =
	                    conn.prepareStatement("insert into drone_delivery values(?,?,?,?,?)");

	            pstmt.setInt(1, nextPk());
	            pstmt.setString(2, bean.getDroneCode());
	            pstmt.setString(3, bean.getOperatorName());
	            pstmt.setString(4, bean.getDeliveryZone());
	            pstmt.setString(5, bean.getStatus());

	            int i = pstmt.executeUpdate();

	            System.out.println(i + " row inserted");

	            conn.commit();

	            pstmt.close();
	            conn.close();

	        } catch (Exception e) {

	            conn.rollback();

	            e.printStackTrace();
	        }

	    }
	    
	    public void update(DroneBean bean) throws Exception {

	        Class.forName(driver);

	        Connection conn = DriverManager.getConnection(url, username, password);

	        PreparedStatement pstmt =
	                conn.prepareStatement("update drone_delivery set droneCode=?, operatorName=?, deliveryZone=?, status=? where droneId=?");

	        pstmt.setString(1, bean.getDroneCode());
	        pstmt.setString(2, bean.getOperatorName());
	        pstmt.setString(3, bean.getDeliveryZone());
	        pstmt.setString(4, bean.getStatus());
	        pstmt.setInt(5, bean.getDroneId());

	        int i = pstmt.executeUpdate();

	        System.out.println(i + " row updated");

	        pstmt.close();
	        conn.close();
	    }
	

}


